generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  role                UserRole             @default(CUSTOMER)
  displayName         String?
  bio                 String?
  csrfExploited       Boolean              @default(false)
  addressId           String?
  address             Address?             @relation(fields: [addressId], references: [id])
  carts               Cart[]
  orders              Order[]
  supportAccessTokens SupportAccessToken[]
  wishlists           Wishlist[]

  @@map("users")
}

model Product {
  id            String         @id @default(cuid())
  name          String
  price         Float
  description   String?
  imageUrl      String
  cartItems     CartItem[]
  reviews       Review[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  @@map("products")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@map("cart_items")
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  addressId String
  address   Address     @relation(fields: [addressId], references: [id])
  total     Float
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  items     OrderItem[]

  @@map("orders")
}

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  quantity        Int
  priceAtPurchase Float

  @@map("order_items")
}

model Address {
  id        String   @id @default(cuid())
  street    String
  city      String
  state     String
  zipCode   String
  country   String
  users     User[]
  orders    Order[]

  @@map("addresses")
}

model Flag {
  id              String         @id @default(cuid())
  flag            String
  slug            String         @unique
  cve             String?
  markdownFile    String
  walkthroughSlug String?
  category        FlagCategory   @default(OTHER)
  difficulty      FlagDifficulty @default(MEDIUM)
  foundFlag       FoundFlag?
  hints           Hint[]

  @@map("flags")
}

model Hint {
  id           String        @id @default(cuid())
  flagId       String
  flag         Flag          @relation(fields: [flagId], references: [id], onDelete: Cascade)
  level        Int
  content      String
  revealedHint RevealedHint?

  @@unique([flagId, level])
  @@map("hints")
}

model RevealedHint {
  id         String   @id @default(cuid())
  hintId     String   @unique
  hint       Hint     @relation(fields: [hintId], references: [id], onDelete: Cascade)
  revealedAt DateTime @default(now())

  @@map("revealed_hints")
}

enum FlagCategory {
  INJECTION
  AUTHENTICATION
  AUTHORIZATION
  REQUEST_FORGERY
  INFORMATION_DISCLOSURE
  INPUT_VALIDATION
  CRYPTOGRAPHIC
  REMOTE_CODE_EXECUTION
  OTHER
}

enum FlagDifficulty {
  EASY
  MEDIUM
  HARD
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  content   String
  author    String
  createdAt DateTime @default(now())

  @@map("reviews")
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model SupportAccessToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("support_access_tokens")
}

model FoundFlag {
  id      String   @id @default(cuid())
  flagId  String
  flag    Flag     @relation(fields: [flagId], references: [id], onDelete: Cascade)
  foundAt DateTime @default(now())

  @@unique([flagId])
  @@map("found_flags")
}

model ProjectInit {
  id          String   @id @default(cuid())
  initializedAt DateTime @default(now())

  @@map("project_init")
}

model VisitorLog {
  id        String   @id @default(cuid())
  ip        String
  userAgent String?
  path      String
  sessionId String?
  createdAt DateTime @default(now())

  @@map("visitor_logs")
}

model Wishlist {
  id        String         @id @default(cuid())
  name      String
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPublic  Boolean        @default(false)
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  items     WishlistItem[]

  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  addedAt    DateTime @default(now())

  @@unique([wishlistId, productId])
  @@map("wishlist_items")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model SupplierOrder {
  id         String   @id @default(cuid())
  supplierId String
  orderId    String
  total      Float
  notes      String?
  createdAt  DateTime @default(now())

  @@map("supplier_orders")
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  discount  Float
  maxUses   Int
  usedCount Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@map("coupons")
}
